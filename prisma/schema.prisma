datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

model Employee {
  id          String       @id @default(uuid())
  employeeId  String       @unique
  email       String?
  name        String
  password    String
  photo       String?
  role        Role         @default(EMPLOYEE)
  createdAt   DateTime     @default(now())
  workStartDate DateTime     @default(now()) @db.Date
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]
  shifts      Shift[]
  leaves      Leave[]
}

model Attendance {
  id         String           @id @default(uuid())
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockIn    DateTime
  clockOut   DateTime?
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  latitude   Float?
  longitude  Float?
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([employeeId, date])
}

model Shift {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  isOff      Boolean  @default(false)
  shiftType  String?
  startTime  String?
  endTime    String?
  location   String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, date])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Leave {
  id         String      @id @default(uuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String
  startDate  DateTime    @db.Date
  endDate    DateTime    @db.Date
  reason     String
  status     LeaveStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

